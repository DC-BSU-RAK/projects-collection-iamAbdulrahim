<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/shape_handle"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About Ritual Builder"
        android:textColor="#F0EDE8"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ritual Builder helps you design intentional days.\n\nThe Ritual tab lets you pick micro-actions and save your personal daily sequence — things like breathing, stretching, journalling, or simply drinking water.\n\nThe Study tab includes a Pomodoro timer to keep you focused, plus a session log where you track what you studied, for how long, and how focused you felt.\n\nMy Day shows your ritual checklist and study summary together — your full day at a glance.\n\nAll your preferences are saved automatically and persist between sessions."
        android:textColor="#888888"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.6"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseInfo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Got it"
        android:textColor="#0D0D0F"
        app:backgroundTint="#E8E0D0"
        app:cornerRadius="14dp"/>

</LinearLayout>
