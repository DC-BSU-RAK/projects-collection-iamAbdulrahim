<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Mood Eq."
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnInfo"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInfo"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="?"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        app:cornerRadius="22dp"
        app:strokeColor="@color/border_subtle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvAppTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvAppTitle"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEquation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/border_subtle"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR EQUATION"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvEquationTokens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="select moods below..."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:minHeight="30dp"
                android:gravity="center_vertical"/>

            <View
                android:id="@+id/viewColorBar"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/shape_color_bar"
                android:visibility="invisible"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/viewColorSwatch"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/shape_circle"
                    android:visibility="invisible"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="italic"
                    android:lineSpacingMultiplier="1.3"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvGridLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:text="MOOD PALETTE"
        android:textColor="@color/text_dim"
        android:textSize="10sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/cardEquation"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMoodGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvGridLabel"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Clear"
            android:textColor="@color/text_secondary"
            android:minWidth="80dp"
            app:cornerRadius="14dp"
            app:strokeColor="@color/border_subtle"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompute"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:text="Compute"
            android:textColor="@color/bg_dark"
            android:enabled="false"
            app:backgroundTint="@color/btn_compute_bg"
            app:cornerRadius="14dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>